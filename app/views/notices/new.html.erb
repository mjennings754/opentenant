<h2>Create a new notice for: <%= @property.address %></h2>
<%= form_with(model: [@organization, @property, @notice]) do |form| %>
<%= form.label :title %>
<%= form.text_field :title %>
<%= form.label :description %>
<%= form.text_area :description %>
<%= form.submit "Create notice", class: 'btn-primary' %>
<% end %>
<div class="container-session mt-10">
<h4>Create your openTenant account</h4>
<%= form_with model: @user do |form| %>
    <%= form.label :username %>
    <p class="caption">This will be visible across the platform.</p>
    <%= form.text_field :username %>
    <%= form.label :firstname %>
    <%= form.text_field :firstname %>
    <%= form.label :lastname %>
    <%= form.text_field :lastname %>
    <%= form.label :email %>
    <%= form.text_field :email %>
    <p class="caption">We will contact you for account-related purposes only.</p>
    <%= form.label :password %>
    <%= form.password_field :password %>
    <%= form.label :password_confirmation %>
    <%= form.password_field :password_confirmation %>
    <%= form.submit "Create an account", class: 'btn-primary' %>
<% end %>
</div>